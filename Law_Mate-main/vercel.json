{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "client/build",
  "installCommand": "npm install && cd client && npm install --legacy-peer-deps",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/search/:path*", "destination": "/api/index" },
    { "source": "/((?!api|search).*)", "destination": "/client/build/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
